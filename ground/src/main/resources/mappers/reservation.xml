<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="reservation">
    <insert id="insert">
        INSERT INTO reservations (userid, groundname, reservation_date)
        VALUES (#{userid},#{groundname},#{reservation_date})
    </insert>
    <select id="check" resultType="map">
        SELECT * from reservations where groundname=#{groundname}
    </select>
    <select id="list" resultType="com.example.ground.dto.ReservationDTO">
    select * from reservations where userid=#{userid}
    </select>
</mapper>
